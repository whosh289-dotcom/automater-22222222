rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Shared Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Concepts
    function isValidConcept(data) {
      return data.keys().hasAll(['name', 'prompt', 'imageUrl', 'ownerId', 'createdAt']) &&
             data.keys().size() >= 5 &&
             data.name is string && data.name.size() <= 100 &&
             data.prompt is string && data.prompt.size() <= 1000 &&
             data.imageUrl is string && data.imageUrl.size() <= 2048 &&
             data.ownerId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /concepts/{conceptId} {
      allow read: if true; // Public gallery
      allow create: if isSignedIn() && isValidConcept(incoming());
      allow update: if isOwner(existing().ownerId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'style', 'color']) &&
                      isValidConcept(incoming());
      allow delete: if isOwner(existing().ownerId);
    }
  }
}
